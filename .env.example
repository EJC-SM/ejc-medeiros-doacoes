# Copie para .env e preencha com os dados do Firebase de PRODUCAO.
# Com isso, `npm run dev` grava e le no mesmo banco usado em producao.

# --- Backend local (API /api/* no Vite) ---
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_DATABASE_SECRET=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Obrigatorio para ESCRITA no Firebase via API local (secret do Realtime Database)
# Sem este valor, leituras podem funcionar mas mutacoes falham.

# Opcional: protege mutacoes administrativas
ADMIN_API_TOKEN=
SESSION_SECRET=

# --- Frontend (leitura realtime opcional no browser) ---
# Se omitir, a API usa FIREBASE_* acima em /api/runtime-config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
