# Copie para .env e preencha com os dados do Firebase de PRODUCAO.
# Com FIREBASE_DATABASE_URL + FIREBASE_DATABASE_SECRET, `npm run dev` usa o mesmo banco da producao.

# --- Backend (API /api/* — Vercel Functions + dev-server local) ---
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_DATABASE_SECRET=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Obrigatorio para ESCRITA no Firebase via API (REST autenticado).
# Sem este valor, leituras podem funcionar mas mutacoes falham.

# Recomendado em producao (nao expor no frontend)
ADMIN_API_TOKEN=
SESSION_SECRET=

# --- Frontend (opcional — raramente necessario) ---
# O browser obtem config via GET /api/runtime-config (usa FIREBASE_* do backend).
# Defina VITE_FIREBASE_* apenas se precisar do SDK sem passar pela API (ex.: teste isolado).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_DATABASE_URL=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
